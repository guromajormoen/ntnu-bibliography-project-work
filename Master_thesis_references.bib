@article{qinEvolutionMicrostructure8002023a,
  title = {Evolution of Microstructure and 800~{$^\circ$}{{C}}/294~{{MPa}} Stress Rupture Property of Cast {{Ni-based}} Superalloys during Long-Term Thermal Exposure: {{Role}} and Behavior of Primary {{MC}} Carbide},
  shorttitle = {Evolution of Microstructure and 800~{$^\circ$}{{C}}/294~{{MPa}} Stress Rupture Property of Cast {{Ni-based}} Superalloys during Long-Term Thermal Exposure},
  author = {Qin, X. Z. and Wang, J. Q. and Cheng, S. H. and Wu, Y. S. and Zhou, L. Z.},
  year = 2023,
  month = aug,
  journal = {Materials Science and Engineering: A},
  volume = {881},
  pages = {145416},
  issn = {0921-5093},
  doi = {10.1016/j.msea.2023.145416},
  urldate = {2026-03-16},
  abstract = {The role and behavior of primary MC carbide and their effects on the microstructure and stress rupture property of the cast Ni-based superalloys during long-term thermal exposure at elevated temperature are systemically investigated in this work. It is found that the chemical compositions of primary MC are proportional to the Nb/Ti and (Ti~+~Nb)/(Mo~+~W) ratios of alloys. During long-term thermal exposure, the thermal stability of primary MC can be quantitatively evaluated by its decomposition degree defined as Dt=(V0-Vt)/V0~\texttimes ~100\%, which is closely associated with the Nb/Ti and (Mo~+~W)/Cr ratios of alloys. The decomposition process, degree, form and mechanism of primary MC are revealed in detail. The STEM observations with the EDS analyses show that primary MC decomposition is an inter-diffusion process of elements between the primary MC carbide and {$\gamma$} matrix, which can increase the volume fraction of {$\gamma$}' phase, restrain the precipitation of topologically close-packed (TCP) phases and promote the coarsening of grain boundaries (GBs). The combination of these microstructural evolutions, together with the appropriate Al~+~Ti~+~Nb and W~+~Mo contents in the matrix, eventually results in a remarkable improvement in the stress rupture property of long-term thermally exposed cast Ni-based superalloys.},
  keywords = {Cast Ni-based superalloys,Long-term thermal exposure,Microstructure,Primary MC carbide,Stress rupture property,Thermal stability},
  file = {/Users/guromajormoen/Zotero/storage/WE4K4W6A/Qin et al. - 2023 - Evolution of microstructure and 800 °C294 MPa stress rupture property of cast Ni-based superalloys.pdf;/Users/guromajormoen/Zotero/storage/Q2ARUJP6/S0921509323008407.html}
}

@article{rakoczyInvestigationPrecipitatesDissolution2021,
  title = {Investigation of the {$\gamma\prime$} {{Precipitates Dissolution}} in a {{Ni-Based Superalloy During Stress-Free Short-Term Annealing}} at {{High Homologous Temperatures}}},
  author = {Rakoczy, {\L}ukasz and {Grudzie{\'n}-Rakoczy}, Ma{\l}gorzata and Hanning, Fabian and Cempura, Grzegorz and Cygan, Rafa{\l} and Andersson, Joel and {Zieli{\'n}ska-Lipiec}, Anna},
  year = 2021,
  month = nov,
  journal = {Metallurgical and Materials Transactions A},
  volume = {52},
  number = {11},
  pages = {4767--4784},
  issn = {1543-1940},
  doi = {10.1007/s11661-021-06420-4},
  urldate = {2026-04-13},
  abstract = {The equiaxed Ni-based superalloy Ren\'e 108 was subjected to short-term annealing at five temperatures between 900~{$^\circ$}C and 1100 {$^\circ$}C. The phase composition, phase lattice parameters, microstructure, stereological parameters, and chemical composition of {$\gamma\prime$} precipitates were investigated by thermodynamic simulations, X-ray diffraction, scanning and transmission electron microscopy, and energy-dispersive X-ray spectroscopy. Analysis of the {$\gamma$} and {$\gamma\prime$} lattice parameters using the Nelson-Riley extrapolation function showed that the misfit parameter for temperatures 900~{$^\circ$}C to 1050 {$^\circ$}C is positive (decreasing from 0.32 to 0.11~pct). At 1100~{$^\circ$}C, the parameter becomes negative, {$\delta~$}=~-~0.18~pct. During the short-term annealing, {$\gamma\prime$} precipitates dissolution occurred progressing more rapidly with increasing temperatures. The surface fraction of {$\gamma\prime$} precipitates decreased with increasing temperature from 0.52 to 0.34. The dissolution of {$\gamma\prime$} precipitates did not only proceed through uninterrupted thinning of each individual precipitate, but also included more complex mechanisms, including splitting. Based on transmission electron microscopy, it was shown that after {$\gamma\prime$} precipitates dissolution, the matrix close to the {$\gamma$}/{$\gamma\prime$} interface is strongly enriched in Co and Cr and depleted in Al.},
  langid = {english},
  file = {/Users/guromajormoen/Zotero/storage/3TM6REQF/Rakoczy et al. - 2021 - Investigation of the γ′ Precipitates Dissolution in a Ni-Based Superalloy During Stress-Free Short-T.pdf}
}

@book{reedSuperalloysFundamentalsApplications2008a,
  title = {The {{Superalloys}}: {{Fundamentals}} and {{Applications}}},
  shorttitle = {The {{Superalloys}}},
  author = {Reed, Roger C.},
  year = 2008,
  month = jul,
  publisher = {Cambridge University Press},
  abstract = {Superalloys are unique high-temperature materials used in gas turbine engines, which display excellent resistance to mechanical and chemical degradation. This book presents the underlying metallurgical principles which have guided their development and practical aspects of component design and fabrication from an engineering standpoint. The topics of alloy design, process development, component engineering, lifetime estimation and materials behaviour are described, with emphasis on critical components such as turbine blading and discs. The first introductory text on this class of materials, it will provide a strong grounding for those studying physical metallurgy at the advanced level, as well as practising engineers. Included at the end of each chapter are exercises designed to test the reader's understanding of the underlying principles presented. Solutions for instructors and additional resources are available at www.cambridge.org/9780521859042.},
  isbn = {978-1-139-45863-4},
