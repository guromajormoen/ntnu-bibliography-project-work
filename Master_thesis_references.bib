@article{zhangEffectPreHeatTreatmentOxidation2023,
  title = {Effect of {{Pre-Heat-Treatment}} on the {{Oxidation Resistance}} of {{MCrAlY Coatings}}: {{A Review}}},
  shorttitle = {Effect of {{Pre-Heat-Treatment}} on the {{Oxidation Resistance}} of {{MCrAlY Coatings}}},
  author = {Zhang, Bangyan and Zheng, Shijie and Dong, Jiajian and Yin, Weiwei and Wu, Hongbin and Tian, Lixi and Liu, Guangming},
  year = 2023,
  month = jul,
  journal = {Coatings},
  volume = {13},
  number = {7},
  pages = {1222},
  publisher = {Multidisciplinary Digital Publishing Institute},
  issn = {2079-6412},
  doi = {10.3390/coatings13071222},
  urldate = {2026-04-02},
  abstract = {High-performance gas turbines and aircraft engines necessitate MCrAlY (M = Ni, Co, or Ni/Co) coatings with exceptional oxidation resistance. Pre-heat-treatment can enhance the performance of MCrAlY bond coatings in the following ways: First, it reduces the porosity of the bond coating and promotes the diffusion of elements within it. Second, pre-heat-treatment allows for the formation of a continuous, dense, and moderately thick layer of pure Al2O3 scale, which helps to delay the formation of mixed oxides. Lastly, proper pre-heat-treatment can increase the grain size of the Al2O3 scale, leading to a lower growth rate of the oxide scale. Additionally, this article proposes new directions for developing more reasonable and effective pre-heat-treatment methods, laying the foundation for the creation of thermal barrier coatings (TBCs) with greater durability and higher performance.},
  copyright = {http://creativecommons.org/licenses/by/3.0/},
